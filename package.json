{
	"type": "module",
	"version": "0.12.3",
	"name": "pkgsz",
	"description": "Get the size of an npm package",
	"license": "MIT",
	"author": "Konstantin Shutkin",
	"keywords": [
		"npm",
		"package",
		"size",
		"cli",
		"tool",
		"bundle"
	],
	"bin": "index.js",
	"readme": "README.md",
	"scripts": {
		"lint": "biome lint index.js",
		"ci:publish": "changeset publish",
		"prepack": "pkgbld prune",
		"test": "c8 --src=. --all -r=html -r=text node --env-file=ci.env test.js"
	},
	"engines": {
		"node": ">=20.12.0"
	},
	"dependencies": {
		"@niceties/draftlog-appender": "^2.1.1",
		"@niceties/logger": "^2.1.1",
		"@niceties/node-parseargs-plus": "^0.5.0",
		"jsonata": "2.0.6",
		"kleur": "4.1.5",
		"pkgbld": "^1.33.1",
		"prompts": "2.4.2",
		"read-package-up": "11.0.0",
		"source-map-explorer": "2.5.3",
		"terminal-columns": "1.4.1"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "2.27.11",
		"@types/node": "^20.14.15",
		"c8": "^10.0.0"
	}
}
